{
	"applicationId": "com.multablox.app",
	"version": "0.9.0",
	"defaultMode": "window",
	"documentRoot": "/frontend/dist",
	"url": "/",
	"enableServer": true,
	"enableNativeAPI": true,
	"nativeAllowList": [
		"server.*",
		"events.*",
		"os.*",
		"filesystem.*",
		"window.*",
		"clipboard.*",
		"computer.*",
		"app.*",
		"storage.*"
	],
	"exportAuthInfo": false,
	"logging": {
		"writeToLogFile": false,
		"enabled": true
	},
	"tokenSecurity": "none",
	"modes": {
		"window": {
			"hidden": true,
			"title": "MultaBlox",
			"width": 1150,
			"height": 720,
			"minWidth": 400,
			"minHeight": 200,
			"exitProcessOnClose": false,
			"useSavedState": false,
			"extendUserAgentWith": "MultaBlox",
			"resizable": false,
			"center": true
		}
	},
	"cli": {
		"binaryName": "multablox",
		"resourcesPath": "/frontend/dist",
		"extensionsPath": "/extensions/",
		"binaryVersion": "6.3.0",
		"clientVersion": "6.3.0",
		"frontendLibrary": {
			"buildCommand": "true",
			"patchFile": "/frontend/index.html",
			"devUrl": "http://localhost:5173",
			"devCommand": "true",
			"projectPath": "/",
			"initCommand": "bun install"
		}
	}
}
