<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>MultaBlox __VERSION__</title>
    <welcome file="welcome.html" mime-type="text/html" />
    <options customize="never" require-scripts="false" />
    <domains enable_localSystem="true" enable_currentUserHome="true" />
    <choices-outline>
        <line choice="default">
            <line choice="com.lucas.multablox.pkg" />
        </line>
    </choices-outline>
    <choice id="default" />
    <choice id="com.lucas.multablox.pkg" visible="false">
        <pkg-ref id="com.lucas.multablox.pkg" />
    </choice>
    <pkg-ref id="com.lucas.multablox.pkg" version="__VERSION__" onConclusion="none">MultaBlox.pkg</pkg-ref>
</installer-gui-script>
